<html>
<head>
    <title>Starting NjordHR</title>
    <hta:application
        id="njordhrStartup"
        applicationname="NjordHR Startup"
        border="thin"
        caption="yes"
        maximizebutton="no"
        minimizebutton="no"
        showintaskbar="yes"
        singleinstance="yes"
        sysmenu="yes"
        windowstate="normal"
    />
    <meta http-equiv="x-ua-compatible" content="IE=9" />
    <style>
        body {
            margin: 0;
            background: #f4f7fb;
            font-family: "Segoe UI", Arial, sans-serif;
            color: #172033;
        }
        .shell {
            width: 520px;
            min-height: 240px;
            margin: 0 auto;
            padding: 28px 30px 24px;
            box-sizing: border-box;
        }
        .brand {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 0.2px;
            margin-bottom: 6px;
        }
        .subhead {
            color: #56627a;
            font-size: 14px;
            margin-bottom: 22px;
        }
        .panel {
            background: #ffffff;
            border: 1px solid #d9e2ef;
            border-radius: 14px;
            box-shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
            padding: 20px 22px;
        }
        .status {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 14px;
        }
        .detail {
            color: #5a677d;
            font-size: 14px;
            line-height: 1.5;
            margin-bottom: 18px;
            min-height: 42px;
        }
        .bar {
            position: relative;
            width: 100%;
            height: 8px;
            overflow: hidden;
            background: #e5edf8;
            border-radius: 999px;
        }
        .bar:after {
            content: "";
            position: absolute;
            top: 0;
            left: -32%;
            width: 32%;
            height: 100%;
            background: linear-gradient(90deg, #4d8bff, #245ef5);
            border-radius: 999px;
            animation: shimmer 1.2s linear infinite;
        }
        .shell.ready .bar:after {
            animation: none;
            left: 0;
            width: 100%;
        }
        .shell.error .bar:after {
            animation: none;
            left: 0;
            width: 100%;
            background: #d14343;
        }
        .hint {
            margin-top: 14px;
            color: #6b7280;
            font-size: 12px;
        }
        .actions {
            margin-top: 18px;
            display: none;
        }
        .shell.error .actions {
            display: block;
        }
        .button {
            display: inline-block;
            margin-right: 10px;
            padding: 10px 14px;
            border-radius: 9px;
            border: 1px solid #c8d3e2;
            background: #ffffff;
            color: #172033;
            font-size: 13px;
            cursor: pointer;
        }
        @keyframes shimmer {
            0% { left: -32%; }
            100% { left: 100%; }
        }
    </style>
    <script language="javascript">
        var shell = new ActiveXObject("WScript.Shell");
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var appData = shell.ExpandEnvironmentStrings("%APPDATA%");
        var runtimeDir = appData + "\\NjordHR\\runtime";
        var statusPath = runtimeDir + "\\startup_status.txt";
        var opened = false;
        var lastState = "";

        function parseStatus(text) {
            var result = {};
            var lines = text.split(/\r?\n/);
            for (var i = 0; i < lines.length; i++) {
                var line = lines[i];
                var idx = line.indexOf("=");
                if (idx <= 0) continue;
                var key = line.substring(0, idx);
                var value = line.substring(idx + 1);
                result[key] = value;
            }
            return result;
        }

        function openLogs() {
            shell.Run('explorer.exe "' + runtimeDir + '"', 1, false);
        }

        function closeSplash() {
            window.close();
        }

        function applyState(data) {
            var state = data["state"] || "starting";
            var message = data["message"] || "Preparing NjordHR...";
            var browserUrl = data["browser_url"] || "";
            document.getElementById("status").innerText = state === "error" ? "Startup failed" : state === "ready" ? "Opening NjordHR" : "Starting NjordHR";
            document.getElementById("detail").innerText = message;
            document.getElementById("hint").innerText = state === "error"
                ? "You can inspect the runtime logs or close this window."
                : "Please wait while NjordHR starts its local services.";

            document.body.className = "shell " + state;
            lastState = state;

            if (state === "ready" && browserUrl && !opened) {
                opened = true;
                shell.Run(browserUrl, 1, false);
                window.setTimeout(closeSplash, 1500);
            }
        }

        function pollStatus() {
            try {
                if (!fso.FileExists(statusPath)) {
                    return;
                }
                var file = fso.OpenTextFile(statusPath, 1);
                var text = file.ReadAll();
                file.Close();
                applyState(parseStatus(text));
            } catch (e) {
                if (lastState !== "error") {
                    document.getElementById("detail").innerText = "Waiting for startup status...";
                }
            }
        }

        function init() {
            window.resizeTo(560, 320);
            window.moveTo(
                Math.max(0, (screen.availWidth - 560) / 2),
                Math.max(0, (screen.availHeight - 320) / 2)
            );
            pollStatus();
            window.setInterval(pollStatus, 400);
        }
    </script>
</head>
<body class="shell starting" onload="init()">
    <div class="brand">NjordHR</div>
    <div class="subhead">Preparing your workspace and local services.</div>
    <div class="panel">
        <div class="status" id="status">Starting NjordHR</div>
        <div class="detail" id="detail">Preparing NjordHR...</div>
        <div class="bar"></div>
        <div class="hint" id="hint">Please wait while NjordHR starts its local services.</div>
        <div class="actions">
            <button class="button" onclick="openLogs()">Open Logs</button>
            <button class="button" onclick="closeSplash()">Close</button>
        </div>
    </div>
</body>
</html>
